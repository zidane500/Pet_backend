<?php

namespace App\Http\Requests;

use Illuminate\Foundation\Http\FormRequest;

class StoreListingRequest extends FormRequest
{
    public function authorize(): bool
    {
        return true;
    }

    public function rules(): array
    {
        return [
            'title'         => 'required|string|min:5|max:255',
            'description'   => 'required|string|min:20|max:3000',
            'price'         => 'required|numeric|min:0|max:999999',
            'type'          => 'required|in:vente,adoption,accouplement',
            'species'       => 'required|string|max:100',
            'breed'         => 'nullable|string|max:100',
            'age_months'    => 'nullable|integer|min:0|max:300',
            'gender'        => 'nullable|in:male,female,unknown',
            'city'          => 'required|string|max:100',
            'address'       => 'nullable|string|max:255',
            'phone'         => 'nullable|string|max:20',
            'images'        => 'nullable|array|max:8',
            'images.*'      => 'string',
            'vaccinated'    => 'nullable|boolean',
            'sterilized'    => 'nullable|boolean',
            'pedigree'      => 'nullable|boolean',
            'health_notes'  => 'nullable|string|max:1000',
        ];
    }

    public function messages(): array
    {
        return [
            'title.required'       => 'Le titre est obligatoire.',
            'title.min'            => 'Le titre doit contenir au moins 5 caractères.',
            'description.required' => 'La description est obligatoire.',
            'description.min'      => 'La description doit contenir au moins 20 caractères.',
            'price.required'       => 'Le prix est obligatoire.',
            'price.numeric'        => 'Le prix doit être un nombre.',
            'price.min'            => 'Le prix ne peut pas être négatif.',
            'type.required'        => 'Le type d\'annonce est obligatoire.',
            'type.in'              => 'Le type doit être : vente, adoption ou accouplement.',
            'species.required'     => 'L\'espèce est obligatoire.',
            'city.required'        => 'La ville est obligatoire.',
            'images.max'           => 'Vous ne pouvez pas uploader plus de 8 images.',
        ];
    }
}