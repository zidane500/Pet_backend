# ─── Application ──────────────────────────────────────────────
APP_NAME=Animali.tn
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Tunis
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

# ─── Frontend URL (CORS) ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Base de données PostgreSQL ───────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=animali_db
DB_USERNAME=animali_user
DB_PASSWORD=

# ─── Cache & Sessions ─────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=localhost

# ─── Queue ────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ─── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@animali.tn
MAIL_FROM_NAME="Animali.tn"

# ─── Filesystem (stockage photos) ────────────────────────────
FILESYSTEM_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Sanctum ──────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

# ─── Laravel Reverb (WebSocket) ───────────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=animali_app
REVERB_APP_KEY=your-reverb-app-key
REVERB_APP_SECRET=your-reverb-app-secret
REVERB_HOST=localhost
REVERB_PORT=8090
REVERB_SCHEME=http

# ─── Vite (pour le dashboard Laravel si utilisé) ──────────────
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Logging ──────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_STACK=single

# ─── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_API=60
RATE_LIMIT_AUTH=10

# ─── Production uniquement ────────────────────────────────────
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.animali.tn
# FRONTEND_URL=https://animali.tn
# DB_HOST=db (nom du service Docker)
# SESSION_DOMAIN=animali.tn
# REVERB_HOST=reverb (nom du service Docker)
# REVERB_SCHEME=https
# LOG_LEVEL=error